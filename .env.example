# ─────────────────────────────────────────────────────────────────────────────
#  Zenta — Variables de entorno
#  Copia este archivo como  backend/.env  y ajusta los valores
#  NUNCA subas el .env real a Git
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB (debe coincidir con docker-compose.yml)
MONGO_USER=zenta
MONGO_PASS=zentapass
MONGO_DB=zenta_db

# JWT — cambia por una cadena larga y aleatoria en producción
JWT_SECRET=super_secret_change_in_prod

# Puerto del backend
PORT=5000

# URI de MongoDB (Docker usa el nombre de servicio "mongo")
MONGODB_URI=mongodb://zenta:zentapass@mongo:27017/zenta_db?authSource=admin

# e.firma — clave AES-256 para cifrar credenciales SAT (cambia en producción)
EFIRMA_SECRET=zenta_efirma_aes256_secret_2024_change_in_prod
